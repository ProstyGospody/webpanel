# Copy to deploy/ansible/group_vars/all.yml and adjust values for your host.
panel_public_host: panel.example.com
panel_public_port: 8443
panel_acme_email: admin@example.com

hy2_domain: hy2.example.com
hy2_port: 443
hy2_stats_port: 8999

mtproxy_public_host: mtproxy.example.com
mtproxy_port: 443
mtproxy_stats_port: 3129
mtproxy_tls_domain: www.cloudflare.com

initial_admin_email: admin@example.com
# Leave empty to auto-generate during deploy.
initial_admin_password: ""

# Optional overrides (normally defaults are fine)
prometheus_enabled: true
