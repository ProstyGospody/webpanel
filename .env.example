# Proxy Panel generated runtime environment example.
# During real deployment values are written to /opt/proxy-panel/.env.generated by deploy/install.sh

APP_ENV=production
PANEL_API_LISTEN_ADDR=127.0.0.1:18080
PANEL_PUBLIC_HOST=panel.example.com
PANEL_PUBLIC_PORT=8443
PANEL_PUBLIC_URL=https://panel.example.com:8443

DATABASE_URL=postgres://proxy_panel:change_me@127.0.0.1:5432/proxy_panel?sslmode=disable
MIGRATIONS_DIR=/opt/proxy-panel/current/migrations

SESSION_COOKIE_NAME=pp_session
CSRF_COOKIE_NAME=pp_csrf
CSRF_HEADER_NAME=X-CSRF-Token
SESSION_TTL=24h
SECURE_COOKIES=true

INTERNAL_AUTH_TOKEN=replace_with_random

HY2_DOMAIN=hy2.example.com
HY2_PORT=443
HY2_CONFIG_PATH=/etc/proxy-panel/hysteria/server.yaml
HY2_STATS_URL=http://127.0.0.1:8999
HY2_STATS_SECRET=replace_with_random
HY2_POLL_INTERVAL=10s

MTPROXY_PUBLIC_HOST=proxy.example.com
MTPROXY_TLS_DOMAIN=proxy.example.com
MTPROXY_PORT=443
MTPROXY_STATS_URL=http://127.0.0.1:3129
MTPROXY_STATS_TOKEN=replace_with_random
MTPROXY_POLL_INTERVAL=10s

PROMETHEUS_ENABLED=true
PROMETHEUS_URL=http://127.0.0.1:9090
PROMETHEUS_QUERY_TIMEOUT=2s

SERVICE_POLL_INTERVAL=30s
MANAGED_SERVICES=proxy-panel-api,proxy-panel-web,hysteria-server,mtproxy
SYSTEMCTL_PATH=/usr/bin/systemctl
SUDO_PATH=/usr/bin/sudo
JOURNALCTL_PATH=/usr/bin/journalctl
SERVICE_LOG_LINES_MAX=200

AUTH_RATE_LIMIT_WINDOW=15m
AUTH_RATE_LIMIT_BURST=10

MTPROXY_SECRETS_PATH=/etc/proxy-panel/mtproxy/secrets.list
MTPROXY_BINARY_PATH=/usr/local/bin/mtproto-proxy
HY2_BINARY_PATH=/usr/local/bin/hysteria

AUTO_MIGRATE=false
