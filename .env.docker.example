APP_ENV=development
PANEL_API_LISTEN_ADDR=0.0.0.0:18080
PANEL_API_INTERNAL_URL=http://api:18080
PANEL_PUBLIC_HOST=localhost
PANEL_PUBLIC_PORT=13000
PANEL_PUBLIC_URL=http://localhost:13000

DATABASE_URL=postgres://proxy_panel:proxy_panel@db:5432/proxy_panel?sslmode=disable
MIGRATIONS_DIR=/workspace/migrations

SESSION_COOKIE_NAME=pp_session
CSRF_COOKIE_NAME=pp_csrf
CSRF_HEADER_NAME=X-CSRF-Token
SESSION_TTL=24h
SECURE_COOKIES=false

INTERNAL_AUTH_TOKEN=dev-internal-auth-token

HY2_DOMAIN=localhost
HY2_PORT=443
HY2_CONFIG_PATH=/workspace/docker/dev-data/hysteria/server.yaml
HY2_STATS_URL=http://127.0.0.1:8999
HY2_STATS_SECRET=dev-hy2-stats-secret
HY2_POLL_INTERVAL=1m

MTPROXY_PUBLIC_HOST=localhost
MTPROXY_TLS_DOMAIN=localhost
MTPROXY_PORT=443
MTPROXY_STATS_URL=http://127.0.0.1:3129
MTPROXY_STATS_TOKEN=dev-mtproxy-stats-token
MTPROXY_POLL_INTERVAL=1m

PROMETHEUS_ENABLED=false
PROMETHEUS_URL=http://127.0.0.1:9090
PROMETHEUS_QUERY_TIMEOUT=2s

SERVICE_POLL_INTERVAL=5m
MANAGED_SERVICES=proxy-panel-api,proxy-panel-web,hysteria-server,mtproxy
SYSTEMCTL_PATH=/bin/echo
SUDO_PATH=/usr/bin/env
JOURNALCTL_PATH=/bin/echo
SERVICE_LOG_LINES_MAX=200

AUTH_RATE_LIMIT_WINDOW=15m
AUTH_RATE_LIMIT_BURST=50

MTPROXY_SECRETS_PATH=/workspace/docker/dev-data/mtproxy/secrets.list
MTPROXY_BINARY_PATH=/bin/echo
HY2_BINARY_PATH=/bin/echo

AUTO_MIGRATE=false

INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=admin12345

WEB_PORT=13000
